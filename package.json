{
  "name": "@silmaril/opencode-firewall-plugin",
  "version": "0.1.0",
  "description": "Classify opencode lifecycle events with Silmaril Firewall, add compact context, and optionally block malicious content at supported boundaries.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "opencode",
    "scripts/install-opencode-assets.mjs",
    "scripts/open-playground.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "install:opencode-assets": "node scripts/install-opencode-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-unit-tests.mjs",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "node scripts/block-publish.mjs"
  },
  "dependencies": {
    "@silmaril-security/sdk": "0.4.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
