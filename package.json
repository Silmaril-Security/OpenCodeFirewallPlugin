{
  "name": "@silmaril/opencode-firewall-plugin",
  "version": "0.2.0",
  "description": "Classify opencode parent and child lifecycle events with Silmaril Firewall and render readable native block decisions.",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "opencode",
    "scripts/install-opencode-assets.mjs",
    "scripts/open-playground.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "install:opencode-assets": "node scripts/install-opencode-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-unit-tests.mjs",
    "pack:dry": "npm pack --dry-run",
    "prepublishOnly": "node scripts/block-publish.mjs"
  },
  "dependencies": {
    "@silmaril-security/sdk": "0.5.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
